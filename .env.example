# 🐾 PetCare+ Platform Environment Variables
# .env.local로 복사하고 실제 값을 입력하세요
# Vercel 배포 시 Dashboard의 Environment Variables에 설정하세요

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📌 필수 설정 (이 3개 없으면 기본 기능 작동 안 함)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Claude API (AI 추천 & 챗봇용)
VITE_ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Supabase (상담 신청 정보 저장)
VITE_SUPABASE_URL=https://cpejxivbyvlpkmthgwfq.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📧 이메일 설정 (상담 신청 확인 메일 발송)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Resend API (이메일 발송 서비스)
# https://resend.com에서 무료 가입
RESEND_API_KEY=re_your_actual_resend_key_here

# 상담 신청 이메일 수신처 (당신의 이메일)
PETCARE_ADMIN_EMAIL=your.email@example.com

# 발신 이메일 주소
PETCARE_FROM_EMAIL=noreply@petcare-plus.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🗺️ Google Maps API (동물병원 검색)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Google Cloud Console에서 발급
# Places API 활성화 필수
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 👤 상담사 정보 (Supabase에 저장될 정보)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 상담사 고유 코드 (consultant_inquiries 테이블에 저장)
VITE_CONSULTANT_CODE=251220019

# 상담사 이름
VITE_CONSULTANT_NAME=이희전

# 상담사 전화번호
VITE_CONSULTANT_PHONE=010-5650-0670

# 상담사 이메일
VITE_CONSULTANT_EMAIL=hejunl@hanmail.net

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📊 Analytics (선택사항 - 있으면 좋음)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_API_ENDPOINT=/api/analytics
VITE_ANALYTICS_BATCH_SIZE=10
VITE_ANALYTICS_FLUSH_INTERVAL=30000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📝 콘텐츠 생성 설정 (선택사항)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

VITE_CONTENT_GENERATION_ENABLED=false
VITE_BLOG_POST_FREQUENCY=daily
VITE_SNS_POST_FREQUENCY=hourly
VITE_CONTENT_LANGUAGE=ko

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🏢 회사 정보 (UI에 표시되는 정보)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

VITE_BUSINESS_NAME=수인AI브릿지
VITE_BUSINESS_REGISTRATION_NUMBER=151-09-03201
VITE_BUSINESS_START_DATE=2026-02-25
VITE_COMPANY_ADDRESS=수원시 팔달구

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🎯 플랫폼 설정
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

VITE_APP_NAME=PetCare+
VITE_APP_VERSION=2.0.0
VITE_APP_TAGLINE=대한민국 No.1 AI 기반 펫보험 비교 플랫폼

# 개발(development) 또는 운영(production)
VITE_ENVIRONMENT=development
