# PetCare+ 환경 변수 설정

# ========================================
# 필수 환경 변수
# ========================================

# Anthropic Claude API (AI 추천 & 챗봇)
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Google Maps API (동물병원 검색)
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ========================================
# 선택 환경 변수
# ========================================

# Google Analytics (방문자 분석)
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXX

# Supabase (상담 신청 데이터 저장)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxx...

# ========================================
# 설정 방법
# ========================================
# 로컬 개발: .env.local 파일 생성 후 위 값 입력
# Vercel: Settings → Environment Variables 에서 설정
