# PetCare+ Platform Environment Variables
# Copy this file to .env.local and fill in actual values

# Claude API Configuration (for chatbot and content generation)
VITE_ANTHROPIC_API_KEY=your_claude_api_key_here

# Supabase Configuration (for data persistence)
VITE_SUPABASE_URL=https://cpejxivbyvlpkmthgwfq.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here
PETCARE_ADMIN_EMAIL=admin@petcare-plus.com
PETCARE_FROM_EMAIL=noreply@petcare-plus.com

# Google Maps API (Hospital Finder)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Analytics Configuration
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_API_ENDPOINT=/api/analytics
VITE_ANALYTICS_BATCH_SIZE=10
VITE_ANALYTICS_FLUSH_INTERVAL=30000

# Content Generation Configuration
VITE_CONTENT_GENERATION_ENABLED=true
VITE_BLOG_POST_FREQUENCY=daily
VITE_SNS_POST_FREQUENCY=hourly
VITE_CONTENT_LANGUAGE=ko

# Autonomous Evolution Settings
VITE_AUTO_OPTIMIZATION_ENABLED=true
VITE_AUTO_OPTIMIZATION_INTERVAL=86400000
VITE_AUTO_A_B_TEST_ENABLED=true
VITE_FEEDBACK_COLLECTION_ENABLED=true

# Business Information
VITE_BUSINESS_NAME=수인AI브릿지
VITE_BUSINESS_REGISTRATION_NUMBER=151-09-03201
VITE_BUSINESS_START_DATE=2026-02-25
VITE_COMPANY_ADDRESS=수원시 팔달구

# Platform Configuration
VITE_APP_NAME=PetCare+
VITE_APP_VERSION=2.0.0
VITE_APP_TAGLINE=대한민국 No.1 AI 기반 펫보험 비교 플랫폼
VITE_ENVIRONMENT=production
